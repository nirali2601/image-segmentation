{
  "version": 2,
  "framework": "python",
  "python": {
    "version": "3.11"
  },
  "functions": {
    "api/*.py": {
      "memory": 3008,
      "maxDuration": 60
    }
  },
  "env": {
    "PYTHONUNBUFFERED": "1"
  },
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ]
}
